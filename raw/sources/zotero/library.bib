}

@online{rajicMultiView3DPoint2025,
  title = {Multi-{{View 3D Point Tracking}}},
  author = {Rajič, Frano and Xu, Haofei and Mihajlovic, Marko and Li, Siyuan and Demir, Irem and Gündoğdu, Emircan and Ke, Lei and Prokudin, Sergey and Pollefeys, Marc and Tang, Siyu},
  date = {2025-08-28},
  eprint = {2508.21060},
  eprinttype = {arXiv},
  eprintclass = {cs},
  doi = {10.48550/arXiv.2508.21060},
  url = {http://arxiv.org/abs/2508.21060},
  urldate = {2025-10-08},
  abstract = {We introduce the first data-driven multi-view 3D point tracker, designed to track arbitrary points in dynamic scenes using multiple camera views. Unlike existing monocular trackers, which struggle with depth ambiguities and occlusion, or prior multi-camera methods that require over 20 cameras and tedious per-sequence optimization, our feed-forward model directly predicts 3D correspondences using a practical number of cameras (e.g., four), enabling robust and accurate online tracking. Given known camera poses and either sensor-based or estimated multi-view depth, our tracker fuses multi-view features into a unified point cloud and applies k-nearest-neighbors correlation alongside a transformer-based update to reliably estimate long-range 3D correspondences, even under occlusion. We train on 5K synthetic multi-view Kubric sequences and evaluate on two real-world benchmarks: Panoptic Studio and DexYCB, achieving median trajectory errors of 3.1 cm and 2.0 cm, respectively. Our method generalizes well to diverse camera setups of 1-8 views with varying vantage points and video lengths of 24-150 frames. By releasing our tracker alongside training and evaluation datasets, we aim to set a new standard for multi-view 3D tracking research and provide a practical tool for real-world applications. Project page available at https://ethz-vlg.github.io/mvtracker.},
  pubstate = {prepublished},
  keywords = {Computer Science - Computer Vision and Pattern Recognition},
  file = {/Users/minsikjeon/Zotero/storage/VPMW5A3L/Rajič et al. - 2025 - Multi-View 3D Point Tracking.pdf;/Users/minsikjeon/Zotero/storage/TITQSMAZ/2508.html}
}

@online{ranftlVisionTransformersDense2021,
  title = {Vision {{Transformers}} for {{Dense Prediction}}},
  author = {Ranftl, René and Bochkovskiy, Alexey and Koltun, Vladlen},
  date = {2021-03-24},
  eprint = {2103.13413},
  eprinttype = {arXiv},
  eprintclass = {cs},
  doi = {10.48550/arXiv.2103.13413},
  url = {http://arxiv.org/abs/2103.13413},
  urldate = {2025-11-04},
  abstract = {We introduce dense vision transformers, an architecture that leverages vision transformers in place of convolutional networks as a backbone for dense prediction tasks. We assemble tokens from various stages of the vision transformer into image-like representations at various resolutions and progressively combine them into full-resolution predictions using a convolutional decoder. The transformer backbone processes representations at a constant and relatively high resolution and has a global receptive field at every stage. These properties allow the dense vision transformer to provide finer-grained and more globally coherent predictions when compared to fully-convolutional networks. Our experiments show that this architecture yields substantial improvements on dense prediction tasks, especially when a large amount of training data is available. For monocular depth estimation, we observe an improvement of up to 28\% in relative performance when compared to a state-of-the-art fully-convolutional network. When applied to semantic segmentation, dense vision transformers set a new state of the art on ADE20K with 49.02\% mIoU. We further show that the architecture can be fine-tuned on smaller datasets such as NYUv2, KITTI, and Pascal Context where it also sets the new state of the art. Our models are available at https://github.com/intel-isl/DPT.},
  pubstate = {prepublished},
  keywords = {Computer Science - Computer Vision and Pattern Recognition},
  file = {/Users/minsikjeon/Zotero/storage/3DCQQFXW/Ranftl et al. - 2021 - Vision Transformers for Dense Prediction.pdf;/Users/minsikjeon/Zotero/storage/65B3V7IT/2103.html}
}

