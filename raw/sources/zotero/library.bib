  url = {http://arxiv.org/abs/2411.04005},
  urldate = {2025-09-30},
  abstract = {Manipulating objects to achieve desired goal states is a basic but important skill for dexterous manipulation. Human hand motions demonstrate proficient manipulation capability, providing valuable data for training robots with multi-finger hands. Despite this potential, substantial challenges arise due to the embodiment gap between human and robot hands. In this work, we introduce a hierarchical policy learning framework that uses human hand motion data for training object-centric dexterous robot manipulation. At the core of our method is a high-level trajectory generative model, learned with a large-scale human hand motion capture dataset, to synthesize human-like wrist motions conditioned on the desired object goal states. Guided by the generated wrist motions, deep reinforcement learning is further used to train a low-level finger controller that is grounded in the robot's embodiment to physically interact with the object to achieve the goal. Through extensive evaluation across 10 household objects, our approach not only demonstrates superior performance but also showcases generalization capability to novel object geometries and goal states. Furthermore, we transfer the learned policies from simulation to a real-world bimanual dexterous robot system, further demonstrating its applicability in real-world scenarios. Project website: https://cypypccpy.github.io/obj-dex.github.io/.},
  pubstate = {prepublished},
  keywords = {Computer Science - Robotics},
  file = {/Users/minsikjeon/Zotero/storage/DVF42F6A/Chen et al. - 2024 - Object-Centric Dexterous Manipulation from Human Motion Data.pdf;/Users/minsikjeon/Zotero/storage/YVN3FVZZ/2411.html}
}

@online{chenReconstructInpaintFinetune2025,
  title = {Reconstruct, {{Inpaint}}, {{Finetune}}: {{Dynamic Novel-view Synthesis}} from {{Monocular Videos}}},
  shorttitle = {Reconstruct, {{Inpaint}}, {{Finetune}}},
  author = {Chen, Kaihua and Khurana, Tarasha and Ramanan, Deva},
  date = {2025-07-16},
  eprint = {2507.12646},
  eprinttype = {arXiv},
  eprintclass = {cs},
  doi = {10.48550/arXiv.2507.12646},
  url = {http://arxiv.org/abs/2507.12646},
  urldate = {2025-11-20},
  abstract = {We explore novel-view synthesis for dynamic scenes from monocular videos. Prior approaches rely on costly test-time optimization of 4D representations or do not preserve scene geometry when trained in a feed-forward manner. Our approach is based on three key insights: (1) covisible pixels (that are visible in both the input and target views) can be rendered by first reconstructing the dynamic 3D scene and rendering the reconstruction from the novel-views and (2) hidden pixels in novel views can be "inpainted" with feed-forward 2D video diffusion models. Notably, our video inpainting diffusion model (CogNVS) can be self-supervised from 2D videos, allowing us to train it on a large corpus of in-the-wild videos. This in turn allows for (3) CogNVS to be applied zero-shot to novel test videos via test-time finetuning. We empirically verify that CogNVS outperforms almost all prior art for novel-view synthesis of dynamic scenes from monocular videos.},
  pubstate = {prepublished},
  keywords = {Computer Science - Computer Vision and Pattern Recognition},
  file = {/Users/minsikjeon/Zotero/storage/QTL565UH/Chen et al. - 2025 - Reconstruct, Inpaint, Finetune Dynamic Novel-view Synthesis from Monocular Videos.pdf;/Users/minsikjeon/Zotero/storage/GLZ5D52B/2507.html}
}

@online{chenTTT3R3DReconstruction2026,
  title = {{{TTT3R}}: {{3D Reconstruction}} as {{Test-Time Training}}},
  shorttitle = {{{TTT3R}}},
  author = {Chen, Xingyu and Chen, Yue and Xiu, Yuliang and Geiger, Andreas and Chen, Anpei},
  date = {2026-03-03},
  eprint = {2509.26645},
  eprinttype = {arXiv},
  eprintclass = {cs},
  doi = {10.48550/arXiv.2509.26645},
  url = {http://arxiv.org/abs/2509.26645},
  urldate = {2026-04-15},
  abstract = {Modern Recurrent Neural Networks have become a competitive architecture for 3D reconstruction due to their linear-time complexity. However, their performance degrades significantly when applied beyond the training context length, revealing limited length generalization. In this work, we revisit the 3D reconstruction foundation models from a Test-Time Training perspective, framing their designs as an online learning problem. Building on this perspective, we leverage the alignment confidence between the memory state and incoming observations to derive a closed-form learning rate for memory updates, to balance between retaining historical information and adapting to new observations. This training-free intervention, termed TTT3R, substantially improves length generalization, achieving a \$2\textbackslash times\$ improvement in global pose estimation over baselines, while operating at 20 FPS with just 6 GB of GPU memory to process thousands of images. Code is available in https://rover-xingyu.github.io/TTT3R},
  pubstate = {prepublished},
  keywords = {Computer Science - Computer Vision and Pattern Recognition},
  file = {/Users/minsikjeon/Zotero/storage/UURK6ZF9/Chen et al. - 2026 - TTT3R 3D Reconstruction as Test-Time Training.pdf;/Users/minsikjeon/Zotero/storage/2PXT4N2Q/2509.html}
}

